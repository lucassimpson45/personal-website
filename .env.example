# YouTube — Content tab shows the 3 latest public uploads from this channel (UC… id, no API key)
YOUTUBE_CHANNEL_ID=

# Resend (https://resend.com) — required for /api/contact
RESEND_API_KEY=

# Verified sender in Resend (e.g. after you verify goluda.ai):
# RESEND_FROM="Lucas Simpson <hello@goluda.ai>"
# If unset, the API uses Resend’s onboarding sender for testing (replace before production).
